{{!< default}}

<div class="grid-bg absolute w-full h-[1000px] top-0 left-0 right-0"></div>

<div class="min-h-screen relative z-20 flex flex-col">

    {{>"header"}}

    {{#post}}

    <main id="trex_main" class="flex-1 py-6 w-full relative z-20">
        <article class="{{post_class}}">
            <div class="ux-arena_container_small relative">
                <div class="max-w-3xl flex flex-col justify-center items-center text-center gap-y-6 mx-auto mb-12">
                    <div class="flex items-center gap-x-1 text-black-600 text-sm font-medium">
                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                        <span>—</span>
                        <span>{{reading_time}}</span>
                    </div>
                    <h1 class="font-semibold text-4xl">{{title}}</h1>
                    {{#if custom_excerpt}}
                        <div class="text-black-600">{{custom_excerpt}}</div>
                    {{/if}}
                    {{>"components/post-meta" showTagFeatured="true" size="" showVisibility="true" }}
                </div>
                {{#if @custom.beyondwords_project_id}}
                <div class="max-w-3xl mx-auto w-full mb-4">
                    <div id="beyondwords-player" class="beyondwords-wrapper"></div>
                </div>
                {{/if}}
                {{#if feature_image}}
                    <div class="mb-12 max-w-3xl mx-auto">
                        <div class="relative overflow-hidden rounded-xl">
                            <img
                                src="{{img_url feature_image size='xxs'}}"
                                data-src="{{img_url feature_image}}"
                                alt="{{#if feature_image_alt}}{{ feature_image_alt }}{{else}}{{title}}{{/if}}"
                                class="w-full h-auto lazytrex-image rounded-xl"
                                loading="lazy"
                            />
                            <span class="lazytrex-blur rounded-xl"></span>
                        </div>
                        {{#if feature_image_caption}}
                            <div class="text-black-600 text-sm [&_a]:underline mt-2">{{feature_image_caption}}</div>
                        {{/if}}
                    </div>
                {{/if}}
            </div>
            <div class="canvas post-content">
                {{content}}
            </div>
        </article>

        <div class="canvas not-prose mt-12">
            <div class="border-t border-black-200 dark:border-black-800 py-8 flex flex-col sm:flex-row sm:items-start gap-4 justify-between">
                <div class="flex gap-4 items-start">
                    <div class="flex shrink-0 -space-x-3">
                        {{#foreach authors}}
                            {{#if profile_image}}
                                <div class="relative w-[56px] h-[56px] rounded-full overflow-hidden">
                                    <a href="{{url}}" class="absolute top-0 left-0 right-0 bottom-0 group hover:cursor-pointer overflow-hidden rounded-full">
                                        <img
                                            src="{{img_url profile_image size='xxs'}}"
                                            data-src="{{img_url profile_image}}"
                                            alt="{{name}}"
                                            class="w-full h-full object-cover object-top lazytrex-image rounded-full group-hover:scale-[1.03] transition-[scale] duration-400"
                                            loading="lazy"
                                        />
                                        <span class="lazytrex-blur rounded-full"></span>
                                    </a>
                                </div>
                            {{else}}
                                <div class="relative w-[56px] h-[56px] rounded-full bg-ghost-accent text-black-950 flex items-center justify-center">
                                    <a href="{{url}}" class="font-heading text-lg trex_taxonomy_name uppercase font-semibold hidden">
                                        {{name}}
                                    </a>
                                </div>
                            {{/if}}
                        {{/foreach}}
                    </div>
                    <div class="flex flex-col gap-y-1.5">
                        <div class="font-semibold text-base [&_a]:text-black-950 dark:[&_a]:text-black-50 [&_a]:hover:underline">
                            {{authors separator=", "}}
                        </div>
                        {{#primary_author}}
                            {{#if bio}}
                                <p class="text-sm text-black-500 dark:text-black-400 max-w-sm leading-relaxed">{{bio}}</p>
                            {{/if}}
                        {{/primary_author}}
                    </div>
                </div>
                {{>"share-post"}}
            </div>
        </div>

        <div class="canvas not-prose mt-8">
            <div class="linkedin-discussion-cta">
                <p class="linkedin-cta-label">Take the argument further</p>
                <p class="linkedin-cta-text">The discussion is on LinkedIn. Disagree loudly. Inspire boldly. Or just tell me I'm wrong.</p>
                <a href="https://www.linkedin.com/in/alaajabawi/" target="_blank" rel="noopener noreferrer" class="linkedin-cta-btn">Continue on LinkedIn →</a>
            </div>
        </div>

        <div class="canvas not-prose mt-12">
            <p class="post-rec-label">If this argument landed — these go further.</p>
        </div>
        {{#next_post}}
        <div class="canvas not-prose mt-4 mb-4">
            <a href="{{url}}" class="next-post-card group flex items-center gap-5">
                <div class="flex-1 min-w-0">
                    <p class="next-post-label">{{t "Continue Reading"}}</p>
                    <h3 class="next-post-title group-hover:underline">{{title}}</h3>
                    <p class="next-post-meta">
                        {{#primary_tag}}<span>{{name}}</span><span class="next-post-dot">·</span>{{/primary_tag}}
                        <span>{{reading_time}}</span>
                    </p>
                </div>
                {{#if feature_image}}
                <div class="next-post-thumb">
                    <img src="{{img_url feature_image size='s'}}" alt="{{title}}" class="w-full h-full object-cover">
                </div>
                {{/if}}
            </a>
        </div>
        {{/next_post}}
        {{>"related-posts"}}
    </main>
    {{/post}}

    {{>"footer"}}
</div>
