{{!< default}} {{#post}} <link
  href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* ── Gate ── */
    .page-gate-content {
      display: none;
    }

    /* ── Portfolio scoped reset ── */
    #portfolio-page {
      font-family: 'Roboto', sans-serif;
      color: #e8e8e8;
      background: #0d0d0d;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    #portfolio-page *,
    #portfolio-page *::before,
    #portfolio-page *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    #portfolio-page ::selection {
      background: #e8e8e8;
      color: #0d0d0d;
    }

    #portfolio-page .pf-wrap {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 32px;
    }

    #portfolio-page .section-label {
      font-size: 20px;
      font-weight: 200;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #555;
    }

    #portfolio-page .divider {
      border: none;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
      margin: 0;
    }

    /* Strength tags */
    #portfolio-page .strength-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 16px;
    }

    #portfolio-page .strength-tag {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.3px;
      padding: 5px 14px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.5);
      border-radius: 3px;
    }

    /* Case study cards */
    #portfolio-page .case-card {
      border: 1px solid rgba(255, 255, 255, 0.07);
      background: rgba(255, 255, 255, 0.03);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 24px;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    #portfolio-page .case-card:hover {
      border-color: rgba(255, 255, 255, 0.18);
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    }

    #portfolio-page .case-accent {
      height: 3px;
    }

    #portfolio-page .case-header {
      padding: 24px 28px 20px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    #portfolio-page .case-header-left {
      flex: 1;
    }

    #portfolio-page .case-meta {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #555;
      margin-bottom: 6px;
    }

    #portfolio-page .case-title {
      font-size: 24px;
      font-weight: 400;
      margin: 0 0 6px;
      line-height: 1.25;
      color: #e8e8e8;
    }

    #portfolio-page .case-sector {
      font-size: 18px;
      color: rgba(255, 255, 255, 0.45);
    }

    #portfolio-page .case-toggle {
      font-size: 12px;
      color: #444;
      margin-top: 4px;
      min-width: 80px;
      text-align: right;
      transition: color 0.2s;
    }

    #portfolio-page .case-card:hover .case-toggle {
      color: #777;
    }

    #portfolio-page .case-metrics {
      padding: 0 28px 20px;
      display: flex;
      gap: 48px;
      flex-wrap: wrap;
    }

    #portfolio-page .case-metric {
      font-size: 16px;
      font-weight: 500;
      letter-spacing: 0.2px;
    }

    #portfolio-page .case-body {
      padding: 0 28px 28px;
      display: none;
    }

    #portfolio-page .case-body.open {
      display: block;
    }

    #portfolio-page .case-body-inner {
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding-top: 24px;
    }

    #portfolio-page .case-field {
      margin-bottom: 24px;
    }

    #portfolio-page .case-field:last-child {
      margin-bottom: 0;
    }

    #portfolio-page .case-field-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #555;
      margin-bottom: 8px;
    }

    #portfolio-page .case-outcome-text {
      font-size: 14px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.7);
    }

    #portfolio-page .placeholder {
      background: repeating-linear-gradient(135deg, transparent, transparent 8px, rgba(255, 255, 255, 0.02) 8px, rgba(255, 255, 255, 0.02) 16px);
      border: 1.5px dashed rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      padding: 16px 20px;
      font-size: 13.5px;
      color: #555;
      line-height: 1.6;
    }

    #portfolio-page .visual-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 500;
      padding: 4px 10px;
      border-radius: 3px;
      background: rgba(255, 255, 255, 0.06);
      color: #777;
      margin: 3px 4px 3px 0;
    }

    /* Image gallery */
    #portfolio-page .img-gallery {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 12px;
    }

    #portfolio-page .img-thumb {
      position: relative;
      flex: 1 1 calc(33.333% - 8px);
      min-width: 160px;
      aspect-ratio: 16 / 10;
      border: 1.5px dashed rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      background: repeating-linear-gradient(135deg, transparent, transparent 8px, rgba(255, 255, 255, 0.02) 8px, rgba(255, 255, 255, 0.02) 16px);
      cursor: pointer;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    #portfolio-page .img-thumb:hover {
      border-color: rgba(255, 255, 255, 0.25);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
    }

    #portfolio-page .img-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: none;
    }

    #portfolio-page .img-thumb.has-img img {
      display: block;
    }

    #portfolio-page .img-thumb.has-img .img-thumb-label,
    #portfolio-page .img-thumb.has-img .img-thumb-icon {
      display: none;
    }

    #portfolio-page .img-thumb-icon {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1.5px solid rgba(255, 255, 255, 0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 6px;
      color: #555;
      font-size: 16px;
    }

    #portfolio-page .img-thumb-label {
      font-size: 11px;
      color: #555;
      text-align: center;
      padding: 0 8px;
      line-height: 1.3;
    }

    #portfolio-page .img-thumb-expand {
      position: absolute;
      top: 6px;
      right: 6px;
      width: 22px;
      height: 22px;
      border-radius: 4px;
      background: rgba(0, 0, 0, 0.7);
      color: #fff;
      font-size: 12px;
      display: none;
      align-items: center;
      justify-content: center;
    }

    #portfolio-page .img-thumb.has-img:hover .img-thumb-expand {
      display: flex;
    }

    /* How I work */
    #portfolio-page .how-card {
      border-left: 3px solid rgba(255, 255, 255, 0.15);
      padding: 20px 24px;
      background: rgba(255, 255, 255, 0.03);
      margin-bottom: 16px;
      transition: background 0.2s;
    }

    #portfolio-page .how-card:hover {
      background: rgba(255, 255, 255, 0.05);
    }

    #portfolio-page .how-card h3 {
      font-size: 28px;
      font-weight: 600;
      margin: 0 0 4px;
      color: #e8e8e8;
    }

    #portfolio-page .how-card p {
      font-size: 16px;
      color: #777;
      margin: 0;
      line-height: 1.5;
    }

    /* Animations */
    #portfolio-page .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    #portfolio-page .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    #portfolio-page .footer-grid {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 32px;
    }

    #portfolio-page .footer-cta {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    #portfolio-page .pf-footer-btn {
      display: block;
      padding: 14px 24px;
      text-align: center;
      min-width: 180px;
      font-size: 13px;
      font-family: 'Roboto', sans-serif;
      font-weight: 500;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 4px;
      color: rgba(255, 255, 255, 0.5);
      text-decoration: none;
      background: transparent;
      transition: border-color 0.2s, color 0.2s;
      cursor: pointer;
    }

    #portfolio-page .pf-footer-btn:hover {
      border-color: rgba(255, 255, 255, 0.35);
      color: #e8e8e8;
    }

    #portfolio-page .pf-footer-btn.accent {
      background: var(--ghost-accent-color);
      border-color: var(--ghost-accent-color);
      color: #000;
      font-weight: 600;
    }

    #portfolio-page .pf-footer-btn.accent:hover {
      opacity: 0.85;
    }

    @media (max-width: 600px) {
      #portfolio-page .pf-wrap {
        padding: 0 20px;
      }

      #portfolio-page .case-title {
        font-size: 20px;
      }

      #portfolio-page .img-thumb {
        min-width: 120px;
      }
    }

    /* Hide reader panel — portfolio uses fixed design, CSS vars don't apply */
#reader-panel, #reader-toggle { display: none !important; }

/* Lightbox (prefixed to avoid Ghost conflict) */
    .pf-lightbox {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(10, 10, 10, 0.92);
      display: none;
      align-items: center;
      justify-content: center;
      cursor: zoom-out;
      padding: 32px;
    }

    .pf-lightbox.open {
      display: flex;
    }

    .pf-lightbox img {
      max-width: 90vw;
      max-height: 85vh;
      border-radius: 8px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
      object-fit: contain;
    }

    .pf-lightbox-caption {
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 13px;
      color: rgba(255, 255, 255, 0.5);
      text-align: center;
      max-width: 500px;
    }

    .pf-lightbox-close {
      position: absolute;
      top: 20px;
      right: 24px;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: none;
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      font-size: 20px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }

    .pf-lightbox-close:hover {
      background: rgba(255, 255, 255, 0.22);
    }

    .pf-lightbox-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: rgba(255, 255, 255, 0.4);
      gap: 12px;
    }

    .pf-lightbox-empty-icon {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      border: 2px dashed rgba(255, 255, 255, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
    }
  </style>

