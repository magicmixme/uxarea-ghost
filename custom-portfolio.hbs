    var HOW_IMAGES = [
      { label: "Process diagram", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Discovery-framing-1.png" },
      { label: "Discovery artifacts", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Discovery-framing-2.png" },
      { label: "Validation loop diagram", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Validation-iteration-01.png" },
      { label: "Usability test findings", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Validation-iteration-02.png" },
      { label: "System architecture", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Systems-thinking-01.png" },
      { label: "Token structure", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Systems-thinking-02.png" },
      { label: "Org / collaboration diagram", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Cross-functional-partnership01-3.png" },
      { label: "Workshop facilitation", src: "https://storage.ghost.io/c/7b/46/7b462c95-1a8f-4c31-a5a0-8eec4b0e2dd3/content/images/2026/05/Cross-functional-partnership02-3.png" }
    ];

    var openCase = null;

    /* ── RENDERING ── */
    function thumbHTML(caseId, idx, img) {
      var has = img.src && img.src.length > 0;
      var h = '<div class="img-thumb' + (has ? " has-img" : "") + '" onclick="event.stopPropagation();openPfLightbox(\'' + caseId + "'," + idx + ')">';
      if (has) {
        h += '<img src="' + img.src + '" alt="' + img.label + '" loading="lazy">';
        h += '<div class="img-thumb-expand">⛶</div>';
      } else {
        h += '<div class="img-thumb-icon">+</div>';
        h += '<div class="img-thumb-label">' + img.label + "</div>";
      }
      return h + "</div>";
    }

    function renderCaseStudies() {
      var c = document.getElementById("case-studies-container");
      if (!c) return;
      var h = "";
      CASES.forEach(function (cs) {
        var isOpen = openCase === cs.id;
        h += '<div class="case-card">';
        h += '<div class="case-accent" style="background:' + cs.accent + '"></div>';
        h += '<div class="case-header" data-case="' + cs.id + '"><div class="case-header-left">';
        h += '<div class="case-meta">' + cs.company + " · " + cs.period + "</div>";
        h += '<h2 class="case-title">' + cs.title + "</h2>";
        h += '<div class="case-sector">' + cs.sector + "</div></div>";
        h += '<div class="case-toggle">' + (isOpen ? "Collapse ↑" : "Expand ↓") + "</div></div>";
        h += '<div class="case-metrics">';
        cs.metrics.forEach(function (m) { h += '<span class="case-metric" style="color:' + cs.accent + '">' + m + "</span>"; });
        h += "</div>";
        h += '<div class="case-body' + (isOpen ? " open" : "") + '"><div class="case-body-inner">';
        h += '<div class="case-field"><div class="case-field-label">Comparable experience hook</div><div class="placeholder">' + cs.hook + "</div></div>";
        h += '<div class="case-field"><div class="case-field-label">The problem</div><div class="placeholder">' + cs.problem + "</div></div>";
        h += '<div class="case-field"><div class="case-field-label">Your process</div><div class="placeholder">' + cs.process + "</div></div>";
        h += '<div class="case-field"><div class="case-field-label">Measurable outcome</div><div class="case-outcome-text">' + cs.outcome + "</div>";
        if (cs.outcomeExtra) h += '<div class="placeholder" style="margin-top:8px">' + cs.outcomeExtra + "</div>";
        h += "</div>";
        h += '<div class="case-field"><div class="case-field-label">What you learned &amp; brought forward</div><div class="placeholder">' + cs.learned + "</div></div>";
        h += '<div class="case-field"><div class="case-field-label">Visual support needed</div><div>';
        cs.visuals.forEach(function (v) { h += '<span class="visual-tag">' + v + "</span>"; });
        h += "</div></div>";
        h += '<div class="case-field"><div class="case-field-label">Project images</div><div class="img-gallery">';
        cs.images.forEach(function (img, i) { h += thumbHTML(cs.id, i, img); });
        h += "</div></div>";
        h += "</div></div></div>";
      });
      c.innerHTML = h;
    }

    /* ── LIGHTBOX ── */
    function openPfLightbox(caseId, idx) {
      var img = caseId === "how" ? HOW_IMAGES[idx] : null;
      if (!img) { for (var i = 0; i < CASES.length; i++) { if (CASES[i].id === caseId) { img = CASES[i].images[idx]; break; } } }
      if (!img) return;
      var ov = document.getElementById("pf-lightbox");
      var li = document.getElementById("pf-lb-img");
      var le = document.getElementById("pf-lb-empty");
      var ll = document.getElementById("pf-lb-empty-label");
      var lc = document.getElementById("pf-lb-caption");
      if (img.src && img.src.length > 0) {
        li.src = img.src; li.alt = img.label; li.style.display = "block"; le.style.display = "none";
        lc.textContent = img.label;
      } else {
        li.style.display = "none"; le.style.display = "flex";
        ll.textContent = img.label; lc.textContent = "Add an image src to populate this slot";
      }
      ov.classList.add("open");
      document.body.style.overflow = "hidden";
    }

    function closePfLightbox() {
      var ov = document.getElementById("pf-lightbox");
      if (ov) ov.classList.remove("open");
      document.body.style.overflow = "";
    }

    document.addEventListener("keydown", function (e) { if (e.key === "Escape") closePfLightbox(); });

    /* ── EVENTS ── */
    document.addEventListener("DOMContentLoaded", function () {
      var caseContainer = document.getElementById("case-studies-container");
      if (caseContainer) {
        caseContainer.addEventListener("click", function (e) {
          var header = e.target.closest(".case-header");
          if (!header) return;
          var id = header.dataset.case;
          openCase = openCase === id ? null : id;
          renderCaseStudies();
        });
      }

      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add("visible"); obs.unobserve(en.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll("#portfolio-page .fade-in").forEach(function (el) { obs.observe(el); });

      renderCaseStudies();

      /* populate how-section thumbnails from HOW_IMAGES */
      var howThumbs = document.querySelectorAll('.how-card .img-thumb');
      HOW_IMAGES.forEach(function(img, idx) {
        var thumb = howThumbs[idx];
        if (!thumb || !img.src) return;
        thumb.classList.add('has-img');
        thumb.innerHTML = '<img src="' + img.src + '" alt="' + img.label + '" loading="lazy"><div class="img-thumb-expand">⛶</div>';
      });
    });

    /* ── GATE ── */
    (function () {
      var overlay = document.getElementById("page-gate-overlay");
      var stored = overlay ? (overlay.dataset.hash || "") : "";
      var formspree = overlay ? (overlay.dataset.formspree || "") : "";
      var portfolioUrl = overlay ? (overlay.dataset.portfolioUrl || "") : "";
      var pageTitle = overlay ? (overlay.dataset.pageTitle || "Portfolio") : "Portfolio";
      var SESSION_KEY = "page_gate_" + btoa(encodeURIComponent(location.pathname));

      var continueBox = document.getElementById("gate-continue");
      var continueLink = document.getElementById("gate-continue-link");
      var switchRow = document.querySelector(".gate-switch-row");

      // Append the validated token as a URL fragment (#k=...) so it stays out of
      // server logs / referrers — the subdomain reads it client-side to validate.
      // Switch "#" to "?" below if the subdomain validates server-side instead.
      function tokenUrl(token) {
        if (!portfolioUrl) return "#";
        if (!token) return portfolioUrl;
        var sep = portfolioUrl.indexOf("#") === -1 ? "#" : "&";
        return portfolioUrl + sep + "k=" + encodeURIComponent(token);
      }

      function showContinue(token) {
        if (continueLink) continueLink.href = tokenUrl(token);
        var pw = document.getElementById("page-gate-form");
        if (pw) pw.style.display = "none";
        var pwSub = document.getElementById("gate-pw-subtitle");
        if (pwSub) pwSub.style.display = "none";
        if (switchRow) switchRow.style.display = "none";
        if (continueBox) continueBox.classList.remove("gate-panel-hidden");
        if (continueLink) continueLink.focus();
      }

      document.body.style.overflow = "hidden";
      if (!stored) { showContinue(""); return; }
      if (sessionStorage.getItem(SESSION_KEY) === stored) { showContinue(stored); return; }

      async function sha256(str) {
        var buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(str.trim()));
        return Array.from(new Uint8Array(buf)).map(function (b) { return b.toString(16).padStart(2, "0"); }).join("");
      }

      var pwForm = document.getElementById("page-gate-form");
      var pwInput = document.getElementById("page-gate-input");
      var pwError = document.getElementById("page-gate-error");
      if (pwForm) {
        pwForm.addEventListener("submit", async function (e) {
          e.preventDefault();
          var val = pwInput ? pwInput.value : "";
          if (!val) return;
          var hash = await sha256(val);
          if (hash === stored) {
            sessionStorage.setItem(SESSION_KEY, stored);
            pwError.textContent = "";
            showContinue(stored);
          } else {
            pwError.textContent = "Incorrect password. Try again.";
            if (pwInput) { pwInput.value = ""; pwInput.focus(); }
          }
        });
      }

      var btnRequest = document.getElementById("show-request-btn");
      var btnPassword = document.getElementById("show-password-btn");
      var panelPw = document.getElementById("gate-panel-password");
      var panelReq = document.getElementById("gate-panel-request");

      if (btnRequest) btnRequest.addEventListener("click", function () {
        panelPw.classList.add("gate-panel-hidden");
        panelReq.classList.remove("gate-panel-hidden");
        btnRequest.style.display = "none";
        btnPassword.style.display = "";
        var n = document.getElementById("access-name"); if (n) n.focus();
      });
      if (btnPassword) btnPassword.addEventListener("click", function () {
        panelReq.classList.add("gate-panel-hidden");
        panelPw.classList.remove("gate-panel-hidden");
        btnPassword.style.display = "none";
        btnRequest.style.display = "";
        if (pwInput) pwInput.focus();
      });

      var reqForm = document.getElementById("page-access-form");
      var reqSuccess = document.getElementById("access-success");
      var reqError = document.getElementById("access-error");
      var reqSubmit = document.getElementById("access-submit-btn");
      if (reqForm) {
        reqForm.addEventListener("submit", async function (e) {
          e.preventDefault();
          var name = (document.getElementById("access-name") || {}).value || "";
          var email = (document.getElementById("access-email") || {}).value || "";
          if (!name || !email) { reqError.textContent = "Please fill in both fields."; return; }
          if (!formspree) { reqError.textContent = "Request form is not configured yet."; return; }
          reqSubmit.disabled = true; reqSubmit.textContent = "Sending…"; reqError.textContent = "";
          try {
            var res = await fetch("https://formspree.io/f/" + formspree, {
              method: "POST",
              headers: { "Content-Type": "application/json", "Accept": "application/json" },
              body: JSON.stringify({ name: name, email: email, page: pageTitle, _subject: "Portfolio access request from " + name })
            });
            if (res.ok) { reqForm.style.display = "none"; reqSuccess.classList.remove("gate-panel-hidden"); }
            else throw new Error();
          } catch (_) {
            reqError.textContent = "Something went wrong. Email me directly at alaa.jabawi@me.com";
            reqSubmit.disabled = false; reqSubmit.textContent = "Send request →";
          }
        });
      }
    })();
  </script>

