<div id="drawerOverlay" class="fixed inset-0 bg-black/90 z-40 hidden opacity-0 transition-opacity duration-300"></div>

<div id="drawer" class="fixed top-0 left-0 h-full w-[100%] xl:w-[60%] 2xl:w-[40%] bg-white dark:bg-black-900 shadow-xl z-[999] transform -translate-x-full transition-transform duration-300 ease-in-out">
    <div class="p-6 overflow-y-auto h-full flex flex-col justify-between">
        <div class="flex justify-end">
            {{>"components/drawer-close"}}
        </div>
        <div id="mobile-nav" class="mt-12 flex-1">
            {{navigation}}
        </div>
        <div class="flex items-center space-x-2.5">
            {{#if @site.twitter}}
                <a href="{{social_url type='twitter'}}" target="_blank" class="hover:opacity-90">
                    <span>
                        {{> "icons/twitter" size="20"}}
                    </span>
                </a>
            {{/if}}
            {{#if @site.facebook}}
                <a href="{{social_url type='facebook'}}" target="_blank" class="hover:opacity-90">
                    <span>
                        {{> "icons/facebook" size="20"}}
                    </span>
                </a>
            {{/if}}
            {{#if @custom.instagram_link}}
                <a href="{{@custom.instagram_link}}" target="_blank" class="hover:opacity-90">
                    <span>
                        {{> "icons/instagram" size="20"}}
                    </span>
                </a>
            {{/if}}
            {{#if @custom.pinterest_link}}
                <a href="{{@custom.pinterest_link}}" target="_blank" class="hover:opacity-90">
                    <span>
                        {{> "icons/pinterest" size="20"}}
                    </span>
                </a>
            {{/if}}
            {{#if @custom.youtube_link}}
                <a href="{{@custom.youtube_link}}" target="_blank" class="hover:opacity-90">
                    <span>
                        {{> "icons/youtube" size="20"}}
                    </span>
                </a>
            {{/if}}
            {{#if @custom.tiktok_link}}
                <a href="{{@custom.tiktok_link}}" target="_blank" class="hover:opacity-90">
                    <span>
                        {{> "icons/tiktok" size="20"}}
                    </span>
                </a>
            {{/if}}
        </div>
    </div>
</div>