<section class="ux-arena_container_small mb-12">
    <div class="flex items-center justify-between mb-3">
        <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-black-500 dark:text-black-500 leading-none">{{t "Where the Argument Starts"}}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {{#get "posts" filter="tag:hash-wts-start" limit="1"}}
            {{#foreach posts}}
                <a href="{{url}}" class="wts-card">
                    <span class="wts-label">{{t "Start Here"}}</span>
                    <span class="wts-title">{{title}}</span>
                    <span class="wts-cta">{{t "Read Now"}} →</span>
                </a>
            {{/foreach}}
        {{/get}}
        {{#get "posts" filter="tag:hash-wts-popular" limit="1"}}
            {{#foreach posts}}
                <a href="{{url}}" class="wts-card">
                    <span class="wts-label">{{t "Most Recognized"}}</span>
                    <span class="wts-title">{{title}}</span>
                    <span class="wts-cta">{{t "Read Now"}} →</span>
                </a>
            {{/foreach}}
        {{/get}}
        {{#get "posts" filter="tag:hash-wts-argued" limit="1"}}
            {{#foreach posts}}
                <a href="{{url}}" class="wts-card">
                    <span class="wts-label">{{t "Most Argued"}}</span>
                    <span class="wts-title">{{title}}</span>
                    <span class="wts-cta">{{t "Read Now"}} →</span>
                </a>
            {{/foreach}}
        {{/get}}
    </div>
</section>
