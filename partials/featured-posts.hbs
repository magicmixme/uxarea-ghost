{{#get "posts" filter="featured:true" limit="5" include="authors,tags"}}
    {{#match posts.length ">" 0}}
        <section class="ux-arena_container_small mb-12">
            <div class="flex items-center justify-between mb-3">
                <h2 class="!font-body text-2xl uppercase font-light">{{t "The Current Argument"}}</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
                {{#foreach posts}}
                    {{#if @first}}
                        <article class="col-span-full grid grid-cols-1 lg:grid-cols-2 lg:gap-6 {{post_class}}">
                            {{#if feature_image}}
                                <div class="relative aspect-video overflow-hidden rounded-xl" style="border: 1px solid #333333;">
                                    <a href="{{url}}" class="absolute inset-0 group hover:cursor-pointer">
                                        <img
                                            src="{{img_url feature_image size='xxs'}}"
                                            data-src="{{img_url feature_image}}"
                                            alt="{{#if feature_image_alt}}{{ feature_image_alt }}{{else}}{{title}}{{/if}}"
                                            class="w-full h-full object-contain lazytrex-image group-hover:scale-[1.03] transition-[scale] duration-400"
                                            loading="lazy"
                                        />
                                        <span class="lazytrex-blur"></span>
                                    </a>
                                </div>
                            {{/if}}
                            <div class="flex flex-col gap-y-4 pt-4 lg:py-8">
                                <div class="flex flex-col gap-y-4">
                                    {{>"components/post-meta" showTagFeatured="false" size="" showVisibility="true"}}
                                    <h3 class="font-semibold text-4xl hover:underline">
                                        <a href="{{url}}">{{title}}</a>
                                    </h3>
                                </div>
                                <div class="flex items-center gap-x-1 text-black-600 text-sm font-medium">
                                    <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                                    {{#primary_author}}
                                        <span>—</span>
                                        <a href="{{url}}" class="hover:underline">{{name}}</a>
                                    {{/primary_author}}
                                </div>
                                {{#if custom_excerpt}}
                                    <div class="text-black-700 dark:text-black-400 prose max-w-none">{{custom_excerpt}}</div>
                                {{/if}}
                                <a href="{{url}}" class="featured-read-cta">{{t "Read the Full Argument"}} →</a>
                            </div>
                        </article>
                    {{else}}
                        {{>"loop" showTagFeatured="false" size="_small" showVisibility="true"}}
                    {{/if}}
                {{/foreach}}
            </div>
        </section>
    {{/match}}
{{/get}}